def gwdgClusterOptions(needsInternet, extraOptions, taskTime = null) {
    def shortQos = taskTime && taskTime.toMillis() < 2.h.toMillis()
        ? '--qos=2h'
        : null

    [
        '--export=ALL',
        needsInternet ? '-C "ssd&inet"' : '-C ssd',
        shortQos,
        extraOptions ?: null,
    ]
        .findAll { it != null }
        .join(' ')
}

def gwdgGpuClusterOptions(needsInternet, gpuType, gpuCount, extraOptions, gpuExtraOptions, taskTime = null) {
    def shortQos = taskTime && taskTime.toMillis() < 2.h.toMillis()
        ? '--qos=2h'
        : null
    def gpuRequest = "--gpus=${gpuType ?: 'A100'}:${gpuCount ?: 1}"

    [
        '--export=ALL',
        needsInternet ? '-C "ssd&inet"' : '-C ssd',
        shortQos,
        gpuRequest,
        extraOptions ?: null,
        gpuExtraOptions ?: null,
    ]
        .findAll { it != null }
        .join(' ')
}

def gwdgDefaultContainerCacheDir = '/projects/scc/MPG/MBMM/scc_mbmm_harder_/dir.project/Softwares/nfx_singularity_cache'

/**
 * Return the shared Apptainer/Singularity cache directory for GWDG jobs.
 */
def gwdgContainerCacheDir() {
    (params.apptainer_cache_dir ?: params.singularity_cache_dir ?: gwdgDefaultContainerCacheDir).toString()
}

/**
 * Return container runtime options using either Apptainer or Singularity params.
 */
def gwdgContainerRunOptions() {
    (params.apptainer_run_options ?: params.singularity_run_options ?: '').toString()
}

/**
 * Return process-level container options with optional GPU flags appended.
 */
def gwdgContainerOptions(extraOptions = null) {
    [
        gwdgContainerRunOptions() ?: null,
        extraOptions ?: null,
    ]
        .findAll { it != null && it.toString().trim() }
        .join(' ')
}

/**
 * Return the shared Apptainer/Singularity image pull timeout for GWDG jobs.
 */
def gwdgContainerPullTimeout() {
    params.apptainer_pull_timeout ?: params.singularity_pull_timeout ?: '4h'
}

def gwdgBeforeScript(attempt, needsInternet, proxyUrl) {
    def tempRoot = attempt == 1
        ? '${SHM_TMPDIR:-${LOCAL_TMPDIR:-${SHARED_SSD_TMPDIR:-${SHARED_TMPDIR:-/tmp}}}}'
        : '${LOCAL_TMPDIR:-${SHARED_SSD_TMPDIR:-${SHARED_TMPDIR:-/tmp}}}'
    def cacheDir = gwdgContainerCacheDir()
    def lines = [
        'module load apptainer',
        "temp_root=\"${tempRoot}\"",
        "container_cache=\"${cacheDir}\"",
        'mkdir -p "${container_cache}"',
        'export TMPDIR="${temp_root}"',
        'export TMP="${temp_root}"',
        'export TEMP="${temp_root}"',
        'export TEMPDIR="${temp_root}"',
        'export APPTAINER_CACHEDIR="${container_cache}"',
        'export SINGULARITY_CACHEDIR="${container_cache}"',
        'export APPTAINER_TMPDIR="${temp_root}"',
        'export SINGULARITY_TMPDIR="${temp_root}"',
        'export APPTAINERENV_TMPDIR="${temp_root}"',
        'export SINGULARITYENV_TMPDIR="${temp_root}"',
        'export APPTAINERENV_TMP="${temp_root}"',
        'export SINGULARITYENV_TMP="${temp_root}"',
        'export APPTAINERENV_APPTAINER_TMPDIR="${temp_root}"',
        'export SINGULARITYENV_SINGULARITY_TMPDIR="${temp_root}"',
        'export APPTAINERENV_APPTAINER_CACHEDIR="${container_cache}"',
        'export APPTAINERENV_SINGULARITY_CACHEDIR="${container_cache}"',
        'export SINGULARITYENV_APPTAINER_CACHEDIR="${container_cache}"',
        'export SINGULARITYENV_SINGULARITY_CACHEDIR="${container_cache}"',
    ]

    if (needsInternet) {
        lines.addAll([
            "export http_proxy=\"${proxyUrl}\"",
            "export https_proxy=\"${proxyUrl}\"",
            "export ftp_proxy=\"${proxyUrl}\"",
            "export HTTP_PROXY=\"${proxyUrl}\"",
            "export HTTPS_PROXY=\"${proxyUrl}\"",
            "export FTP_PROXY=\"${proxyUrl}\"",
            "export APPTAINERENV_http_proxy=\"${proxyUrl}\"",
            "export APPTAINERENV_https_proxy=\"${proxyUrl}\"",
            "export APPTAINERENV_ftp_proxy=\"${proxyUrl}\"",
            "export APPTAINERENV_HTTP_PROXY=\"${proxyUrl}\"",
            "export APPTAINERENV_HTTPS_PROXY=\"${proxyUrl}\"",
            "export APPTAINERENV_FTP_PROXY=\"${proxyUrl}\"",
            "export SINGULARITYENV_http_proxy=\"${proxyUrl}\"",
            "export SINGULARITYENV_https_proxy=\"${proxyUrl}\"",
            "export SINGULARITYENV_ftp_proxy=\"${proxyUrl}\"",
            "export SINGULARITYENV_HTTP_PROXY=\"${proxyUrl}\"",
            "export SINGULARITYENV_HTTPS_PROXY=\"${proxyUrl}\"",
            "export SINGULARITYENV_FTP_PROXY=\"${proxyUrl}\"",
        ])
    }

    lines.join('\n')
}

params {
    config_profile_description = 'The GWDG SCC HPC profile with SLURM, Apptainer/Singularity, and SHM-first temporary storage.'
    config_profile_contact     = 'GWDG SCC user profile'
    config_profile_url         = 'https://docs.hpc.gwdg.de/how_to_use/storage_systems/temporary_storage/index.html'
    max_memory                 = 2.TB
    max_cpus                   = 96
    max_time                   = 48.h
    queue_short                = 'scc-cpu,medium'
    queue_standard             = 'scc-cpu,medium'
    queue_highmem              = 'scc-cpu,medium'
    queue_gpu                  = 'scc-gpu'
    gpu_type                   = 'A100'
    gpus                       = 1
    gpu_container_options      = '--nv'
    executor_exit_read_timeout = '180 min'
    singularity_cache_dir      = gwdgDefaultContainerCacheDir
    apptainer_cache_dir        = null
    singularity_pull_timeout   = '4h'
    apptainer_pull_timeout     = null
    gwdg_proxy_url             = 'http://www-cache.gwdg.de:3128'
}

process {
    executor = 'slurm'
    queue = params.queue_standard
    clusterOptions = {
        gwdgClusterOptions(false, params.slurm_cluster_options, task.time)
    }
    resourceLimits = [
        memory: 2.TB,
        cpus: 96,
        time: 48.h,
    ]
    containerOptions = { gwdgContainerOptions() }
    scratch = '$LOCAL_TMPDIR'
    stageOutMode = 'copy'
    beforeScript = {
        gwdgBeforeScript(task.attempt as int, false, params.gwdg_proxy_url)
    }

    // Use a regex selector so these settings layer onto the main process selectors.
    withName: 'DOWNLOAD_SRA_METADATA|RESOLVE_SRR_METADATA|DOWNLOAD_SRR' {
        clusterOptions = {
            gwdgClusterOptions(true, params.slurm_cluster_options, task.time)
        }
        beforeScript = {
            gwdgBeforeScript(task.attempt as int, true, params.gwdg_proxy_url)
        }
    }

    withLabel: gpu {
        queue = params.queue_gpu
        clusterOptions = {
            gwdgGpuClusterOptions(
                false,
                params.gpu_type,
                params.gpus,
                params.slurm_cluster_options,
                params.gpu_cluster_options,
                task.time
            )
        }
        containerOptions = {
            gwdgContainerOptions(params.gpu_container_options ?: '--nv')
        }
        beforeScript = {
            gwdgBeforeScript(task.attempt as int, false, params.gwdg_proxy_url)
        }
    }
}

executor {
    queueSize = params.executor_queue_size ?: 2000
    exitReadTimeout = params.executor_exit_read_timeout
}

singularity {
    enabled = false
    autoMounts = true
    cacheDir = { gwdgContainerCacheDir() }
    runOptions = { gwdgContainerRunOptions() }
    pullTimeout = { gwdgContainerPullTimeout() }
}

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = { gwdgContainerCacheDir() }
    runOptions = { gwdgContainerRunOptions() }
    pullTimeout = { gwdgContainerPullTimeout() }
}

docker {
    enabled = false
}
