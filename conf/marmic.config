// Marmic SLURM profile based on /home/ashima/nextflow_marmic.config.

params {
    config_profile_description = 'Marmic SLURM profile with shared NFS workDir and Apptainer/Singularity cache support.'
    config_profile_contact     = 'Marmic user profile'
    config_profile_url         = 'local Marmic configuration'

    max_memory                 = 2.TB
    max_cpus                   = 100
    max_time                   = 1000.h
    executor_queue_size        = 30
    executor_queue_stat_interval = '2 min'
    executor_submit_rate_limit = '10/1s'
    executor_poll_interval     = '30 sec'
    singularity_cache_dir      = null
    apptainer_cache_dir        = null
    singularity_pull_timeout   = '4h'
    apptainer_pull_timeout     = null
}

cleanup = false

process {
    executor = 'slurm'
    clusterOptions = '--export=ALL'

    resourceLimits = [
        cpus: 100,
        memory: 2.TB,
        time: 1000.h,
    ]

    withLabel: assembly {
        cpus = { Math.min(60 * task.attempt, params.max_cpus as int) }
        memory = { [1000.GB * task.attempt, params.resource_memory_limit()].min() }
        time = { [48.h * task.attempt, params.resource_time_limit()].min() }
    }

    withLabel: process_medium {
        cpus = { Math.min(15 * task.attempt, params.max_cpus as int) }
        memory = { [50.GB * task.attempt, params.resource_memory_limit()].min() }
        time = { [24.h * task.attempt, params.resource_time_limit()].min() }
    }

    withLabel: run_local {
        executor = 'local'
        scratch = false
    }
}

executor {
    queueSize = params.executor_queue_size ?: 30
    queueStatInterval = params.executor_queue_stat_interval ?: '2 min'
    submitRateLimit = params.executor_submit_rate_limit ?: '10/1s'
    pollInterval = params.executor_poll_interval ?: '30 sec'
}

singularity {
    enabled = false
    autoMounts = true
    cacheDir = (
        params.apptainer_cache_dir
        ?: params.singularity_cache_dir
        ?: (
            new File("/bioinf/${env('USER')}").exists()
            ? "/bioinf/${env('USER')}/nfx_singularity_cache"
            : "/bioinf/home/${env('USER')}/nfx_singularity_cache"
        )
    ).toString()
    envWhitelist = 'http_proxy,https_proxy,no_proxy,HTTP_PROXY,HTTPS_PROXY,NO_PROXY,SSL_CERT_FILE,SSL_CERT_DIR'
    pullTimeout = params.apptainer_pull_timeout ?: params.singularity_pull_timeout ?: '4h'
}

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = (
        params.apptainer_cache_dir
        ?: params.singularity_cache_dir
        ?: (
            new File("/bioinf/${env('USER')}").exists()
            ? "/bioinf/${env('USER')}/nfx_singularity_cache"
            : "/bioinf/home/${env('USER')}/nfx_singularity_cache"
        )
    ).toString()
    envWhitelist = 'http_proxy,https_proxy,no_proxy,HTTP_PROXY,HTTPS_PROXY,NO_PROXY,SSL_CERT_FILE,SSL_CERT_DIR'
    pullTimeout = params.apptainer_pull_timeout ?: params.singularity_pull_timeout ?: '4h'
}

conda {
    enabled = false
}

trace {
    enabled = true
    file = 'trace.tsv'
    overwrite = true
    fields = 'process,tag,status,cpus,memory,time,duration,rchar,wchar,read_bytes,write_bytes,workdir,scratch'
}

report {
    enabled = true
    file = 'report.html'
    overwrite = true
}

timeline {
    enabled = true
    file = 'timeline.html'
    overwrite = true
}
