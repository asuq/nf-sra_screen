//Profile config names for nf-core/configs
params {
    config_profile_description = 'The Okinawa Institute of Science and Technology Graduate University (OIST) HPC cluster profile with synchronised Apptainer/Singularity settings.'
    config_profile_contact     = 'OISTs Bioinformatics User Group <BioinfoUgrp@oist.jp>'
    config_profile_url         = 'https://github.com/nf-core/configs/blob/master/docs/oist.md'
}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = params.singularity_cache_dir ?: params.apptainer_cache_dir ?: "${baseDir}/.singularity-cache"
    pullTimeout = params.singularity_pull_timeout ?: params.apptainer_pull_timeout ?: '100m'
    runOptions = params.singularity_run_options ?: params.apptainer_run_options ?: '--cleanenv'
}

apptainer {
    autoMounts = true
    cacheDir = params.apptainer_cache_dir ?: params.singularity_cache_dir ?: "${baseDir}/.singularity-cache"
    pullTimeout = params.apptainer_pull_timeout ?: params.singularity_pull_timeout ?: '100m'
    runOptions = params.apptainer_run_options ?: params.singularity_run_options ?: '--cleanenv'
}

process {
    resourceLimits = [
        memory: 750.GB,
        cpus: 128,
        time: 720.h
    ]
    executor = 'slurm'
    queue    = params.queue_standard
}

params {
    max_memory     = 750.GB
    max_cpus       = 128
    max_time       = 720.h
    queue_short    = 'short'
    queue_standard = 'compute'
    queue_highmem  = 'largemem'
}
