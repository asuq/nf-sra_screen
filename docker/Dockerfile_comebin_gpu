FROM condaforge/mambaforge:24.9.2-0

ARG CONDA_ENV_NAME='comebin'

ENV CONDA_DIR=/opt/conda \
    MAMBA_NO_BANNER=1 \
    DEBIAN_FRONTEND=noninteractive \
    PATH=$CONDA_DIR/envs/$CONDA_ENV_NAME/bin:$PATH

WORKDIR /work

RUN mamba create -y -n "${CONDA_ENV_NAME}" \
    -c conda-forge -c bioconda \
    "python=3.7" \
    "comebin=1.0.4" \
    "pip" \
    && pip install --no-cache-dir --force-reinstall \
      --index-url https://download.pytorch.org/whl/cu117 \
      "torch==1.13.1" \
    && mamba clean --all --yes

RUN python - <<'PY'
"""Validate that the image contains CUDA-enabled PyTorch."""
import torch

assert torch.version.cuda is not None, "PyTorch CUDA runtime is missing"
print(f"torch={torch.__version__} cuda={torch.version.cuda}")
PY

CMD ["/bin/bash"]
