// --------------------------- Parameters -------------------------------------
params {
  // Required parameters
  sra           = null
  fastq_tsv     = null
  binning_tsv   = null

  // Optional parameters
  taxdump       = null
  uniprot_db    = null
  taxa          = null
  gtdb_ncbi_map = null
  sandpiper_db  = null
  singlem_db    = null
  checkm2_db     = null
  noassembly    = false
  binning       = false
  binners       = 'metabat,semibin,rosella'
  refiners      = 'dastool'
  semibin_environment = 'global'
  gpu           = false

  // Misc
  help        = false
  version     = '0.3.3'
  outdir      = 'output'
  max_retries = 3

  // Resource parameters
  max_cpus    = 4
  max_memory  = 8.GB
  max_time    = 24.h

  // Optional scheduler parameters
  queue_short            = null
  queue_standard         = null
  queue_highmem          = null
  queue_gpu              = null
  gpu_type               = 'A100'
  gpus                   = 1
  executor_queue_size    = null
  slurm_cluster_options  = null
  gpu_cluster_options    = null
  singularity_cache_dir  = null
  singularity_run_options = null
  gpu_container_options  = null
}

// -=---------------=---------- Environment -----------------------------------
manifest {
  nextflowVersion = '25.04.8'
}

plugins {
  id 'nf-boost@~0.6.0'
}

boost {
  // Avoid removing large binner/refiner work outputs while publishDir is still
  // copying them to the final output directory.
  cleanup = false
  cleanupInterval = '60s'
}

workDir = "work"
cleanup = true

// ---------------------------- Containers ------------------------------------
process {
  errorStrategy = { task.attempt <= params.max_retries ? 'retry' : 'ignore' }
  maxRetries    = params.max_retries
  maxErrors     = -1

  // shell = ['/bin/bash', '-euo', 'pipefail']

  withLabel: assembly {
    maxForks = 10
  }

  withLabel: binning {
    maxForks = 10
  }

  withLabel: gpu {
    maxForks = 10
    queue = { params.queue_gpu ?: params.queue_standard }
    clusterOptions = {
      [
        params.slurm_cluster_options ?: null,
        params.gpu_cluster_options ?: null,
      ]
        .findAll { it != null && it.toString().trim() }
        .join(' ')
    }
    containerOptions = { params.gpu_container_options ?: params.singularity_run_options ?: '' }
  }

  withName: VALIDATE_TAXA {
    errorStrategy = 'terminate'
    container = "quay.io/asuq1617/nf-sra_screen_taxa:${params.version}"
    queue  = { params.queue_short }
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 10.min * task.attempt, params.max_time ].min() }
  }

  withName: DOWNLOAD_SRA_METADATA {
    container = "quay.io/asuq1617/iseq:1.9.8"
    maxForks = 10
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 1.h * task.attempt, params.max_time ].min() }
  }

  withName: RESOLVE_SRR_METADATA {
    container = "quay.io/asuq1617/iseq:1.9.8"
    maxForks = 10
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 1.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 10.min * task.attempt, params.max_time ].min() }
  }

  withName: SANDPIPER {
    container = "quay.io/asuq1617/singlem:0.20.3"
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 10.min * task.attempt, params.max_time ].min() }
  }

  withName: DOWNLOAD_SRR {
    container = "quay.io/asuq1617/iseq:1.9.8"
    maxForks = 10
    cpus   = { Math.min( 4, params.max_cpus as int ) }
    memory = { [ 8.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 12.h * task.attempt, params.max_time ].min() }
  }

  withName: SINGLEM {
    container = "quay.io/asuq1617/singlem:0.20.3"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: METASPADES {
    container = "quay.io/asuq1617/nf-sra_screen_metaspades:${params.version}"
    queue  = { task.attempt < 3 ? params.queue_standard : params.queue_highmem }
    cpus   = { task.attempt < 3 ? Math.min( 128, params.max_cpus as int ) : Math.min( 36, params.max_cpus as int )}
    memory = { task.attempt < 3 ? [ 500.GB ,  params.max_memory ].min() : [ 750.GB ,  params.max_memory ].min()}
    time   = { task.attempt < 3 ? [ 96.h, params.max_time ].min() : [ 336.h, params.max_time ].min()}
  }

  withName: UNICYCLER {
    container = "quay.io/asuq1617/nf-sra_screen_unicycler:${params.version}"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB  * task.attempt,  params.max_memory ].min() }
    time   = { [ 96.h * task.attempt, params.max_time ].min() }
  }

  withName: METAFLYE_NANO {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    queue  = { task.attempt < 3 ? params.queue_standard : params.queue_highmem }
    cpus   = { task.attempt < 3 ? Math.min( 128, params.max_cpus as int ) : Math.min( 36, params.max_cpus as int )}
    memory = { task.attempt < 3 ? [ 500.GB, params.max_memory ].min() : [ 750.GB, params.max_memory ].min()}
    time   = { task.attempt < 3 ? [ 96.h, params.max_time ].min() : [ 336.h, params.max_time ].min()}
  }

  withName: METAFLYE_PACBIO {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    queue  = { task.attempt < 3 ? params.queue_standard : params.queue_highmem }
    cpus   = { task.attempt < 3 ? Math.min( 128, params.max_cpus as int ) : Math.min( 36, params.max_cpus as int )}
    memory = { task.attempt < 3 ? [ 500.GB, params.max_memory ].min() : [ 750.GB, params.max_memory ].min()}
    time   = { task.attempt < 3 ? [ 96.h, params.max_time ].min() : [ 336.h, params.max_time ].min()}
  }

  withName: METAFLYE_HIFI {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB  * task.attempt,  params.max_memory ].min() }
    time   = { [ 96.h * task.attempt, params.max_time ].min() }
  }

  withName: MYLOASM {
    container = "quay.io/asuq1617/nf-sra_screen_myloasm:${params.version}"
    queue  = { task.attempt < 3 ? params.queue_standard : params.queue_highmem }
    cpus   = { task.attempt < 3 ? Math.min( 128, params.max_cpus as int ) : Math.min( 36, params.max_cpus as int )}
    memory = { task.attempt < 3 ? [ 500.GB, params.max_memory ].min() : [ 750.GB, params.max_memory ].min()}
    time   = { task.attempt < 3 ? [ 96.h, params.max_time ].min() : [ 336.h, params.max_time ].min()}
  }

  withName: DIAMOND {
    container = "quay.io/biocontainers/diamond:2.1.13--h13889ed_0"
    queue  = { task.attempt < 3 ? params.queue_standard : params.queue_highmem }
    cpus   = { task.attempt < 3 ? Math.min( 128, params.max_cpus as int ) : Math.min( 36, params.max_cpus as int )}
    memory = { [ 100.GB * task.attempt, params.max_memory ].min() }
    time   = { task.attempt < 3 ? [ 96.h, params.max_time ].min() : [ 336.h, params.max_time ].min()}
  }

  withName: BLOBTOOLS {
    container = "docker.io/genomehubs/blobtoolkit:4.4.6"
    queue = { params.queue_short }
    cpus   = { Math.min( 16, params.max_cpus as int ) }
    memory = { [ 50.GB, params.max_memory ].min() }
    time   = { [ 2.h, params.max_time ].min() }
  }

  withName: EXTRACT_TAXA {
    container = "quay.io/asuq1617/nf-sra_screen_taxa:${params.version}"
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 1.h * task.attempt, params.max_time ].min() }
  }

  withName: MAP_SHORT {
    container = "quay.io/asuq1617/nf-sra_screen_unicycler:${params.version}"
    cpus   = { Math.min( 16 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 24.h * task.attempt, params.max_time ].min() }
  }

  withName: MAP_NANO {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    cpus   = { Math.min( 16 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 24.h * task.attempt, params.max_time ].min() }
  }

  withName: MAP_PACBIO {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    cpus   = { Math.min( 16 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 24.h * task.attempt, params.max_time ].min() }
  }

  withName: MAP_HIFI {
    container = "quay.io/asuq1617/nf-sra_screen_metaflye:${params.version}"
    cpus   = { Math.min( 16 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 24.h * task.attempt, params.max_time ].min() }
  }

  withName: METABAT {
    container = "quay.io/biocontainers/metabat2:2.17--hd498684_0"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: COMEBIN {
    container = "quay.io/biocontainers/comebin:1.0.4--hdfd78af_1"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: COMEBIN_GPU {
    container = "quay.io/asuq1617/comebin:1.0.4-cuda117"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: VAMB {
    container = "quay.io/biocontainers/vamb:5.0.4--pyhdfd78af_0"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: VAMB_GPU {
    container = "quay.io/asuq1617/vamb:5.0.4-cuda12"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: LORBIN {
    container = "quay.io/asuq1617/lorbin:0.1.0-cpu"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: LORBIN_GPU {
    container = "quay.io/asuq1617/lorbin:0.1.0-gpu"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: SEMIBIN {
    container = "quay.io/biocontainers/semibin:2.2.0--pyhdfd78af_0"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: ROSELLA {
    container = "quay.io/asuq1617/rosella:0.5.4"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: DASTOOL {
    container = "quay.io/biocontainers/das_tool:1.1.7--r44hdfd78af_1"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: BINETTE {
    container = "quay.io/biocontainers/binette:1.2.1--pyh7e72e81_0"
    queue  = { task.attempt == 1 ? params.queue_short : params.queue_standard }
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.max_memory ].min() }
    time   = { [ 2.h * task.attempt, params.max_time ].min() }
  }

  withName: CREATE_EMPTY_SUMMARY {
    // Pure shell helpers run on the host to avoid Singularity bind failures.
    executor = 'local'
    maxForks = 10
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 1.h * task.attempt, params.max_time ].min() }
  }

  withName: CREATE_EMPTY_FAILURE_SUMMARY {
    executor = 'local'
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.max_memory ].min() }
    time   = { [ 1.h * task.attempt, params.max_time ].min() }
  }

  withName: APPEND_SUMMARY {
    executor = 'local'
    maxForks = 100
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 1.GB, params.max_memory ].min() }
    time   = { [ 10.min * task.attempt, params.max_time ].min() }
  }
}


// --------------------------- Singularity engine -----------------------------
singularity {
  autoMounts  = true
  cacheDir    = params.singularity_cache_dir ?: "${baseDir}/.singularity-cache"
  pullTimeout = '100m'
  runOptions  = params.singularity_run_options ?: '--cleanenv'
}


// ------------------------------ Reports -------------------------------------
timeline {
  enabled   = true
  file      = "execution-reports/timeline.html"
  overwrite = true
}

report {
  enabled   = true
  file      = "execution-reports/report.html"
  overwrite = true
}

trace {
  enabled   = true
  file      = "execution-reports/trace.tsv"
  overwrite = true
}

// ------------------------------ Profiles ------------------------------------
profiles {
  oist {
    includeConfig "${projectDir}/conf/oist.config"
  }

  gwdg {
    includeConfig "${projectDir}/conf/gwdg.config"
  }

  slurm {
    process.executor = 'slurm'
    singularity.enabled = true
    executor.queueSize = params.executor_queue_size ?: 2000
    params.max_cpus    = 16
    params.max_memory  = 32.GB
    params.max_time    = 24.h
  }

  local {
    process.executor = 'local'
    docker.enabled = true
    executor.queueSize = 4
    params.max_cpus    = 8
    params.max_memory  = 16.GB
    params.max_time    = 24.h
  }

  debug {
    docker.enabled = true
    cleanup = false
    trace.fields = 'task_id,process,tag,status,hash,cpus,memory,time,realtime,exit,attempt'
    executor.queueSize = 1
    params.max_cpus    = 4
    params.max_memory  = 8.GB
    params.max_time    = 24.h
  }

  test {
  }
}
