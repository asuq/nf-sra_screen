// --------------------------- Parameters -------------------------------------
params {
  // Required parameters
  sra           = null
  fastq_tsv     = null
  binning_tsv   = null
  assembler     = null
  assemblers    = 'auto'

  // Optional parameters
  taxdump       = null
  uniprot_db    = null
  taxa          = null
  gtdb_ncbi_map = null
  sandpiper_db  = null
  singlem_db    = null
  checkm2_db    = null
  noassembly    = false
  binning       = false
  binners       = 'all-compatible'
  refiners      = 'binette'
  semibin_environment = 'global'
  gpu           = false

  // Misc
  help        = false
  version     = '0.3.3'
  outdir      = 'output'
  max_retries = 3

  // Resource parameters
  max_cpus    = 4
  max_memory  = 8.GB
  max_time    = 24.h
  resource_memory_limit = { nextflow.util.MemoryUnit.of(params.max_memory.toString()) }
  resource_time_limit   = { nextflow.util.Duration.of(params.max_time.toString()) }

  // Optional scheduler parameters
  queue_short            = null
  queue_standard         = null
  queue_highmem          = null
  queue_gpu              = null
  gpu_type               = null
  gpus                   = 1
  executor_queue_size    = null
  slurm_cluster_options  = null
  gpu_cluster_options    = null
  apptainer_cache_dir    = null
  apptainer_run_options  = null
  apptainer_pull_timeout = null
  singularity_cache_dir  = null
  singularity_run_options = null
  singularity_pull_timeout = null
  gpu_container_options  = null
}

// -=---------------=---------- Environment -----------------------------------
manifest {
  nextflowVersion = '>=26.04.0'
}

workDir = "work"
cleanup = true

// ---------------------------- Containers ------------------------------------
process {
  errorStrategy = { task.attempt <= params.max_retries ? 'retry' : 'ignore' }
  maxRetries    = params.max_retries
  maxErrors     = -1

  // shell = ['/bin/bash', '-euo', 'pipefail']

  withLabel: assembly {
    maxForks = 10
  }

  withLabel: binning {
    maxForks = 10
  }

  withLabel: gpu {
    maxForks = 10
    clusterOptions = {
      [
        params.slurm_cluster_options ?: null,
        params.gpu_cluster_options ?: null,
      ]
        .findAll { option -> option != null && option.toString().trim() }
        .join(' ')
    }
    containerOptions = {
      [
        params.apptainer_run_options ?: params.singularity_run_options ?: null,
        params.gpu_container_options ?: null,
      ]
        .findAll { option -> option != null && option.toString().trim() }
        .join(' ')
    }
  }

  withName: VALIDATE_TAXA {
    errorStrategy = 'terminate'
    container = "quay.io/asuq1617/nf-sra_screen_taxa:${params.version}"
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 10.min * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: DOWNLOAD_SRA_METADATA {
    container = "quay.io/asuq1617/iseq:1.9.8-sratools3.4.1"
    maxForks = 10
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 1.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: RESOLVE_SRR_METADATA {
    container = "quay.io/asuq1617/iseq:1.9.8-sratools3.4.1"
    maxForks = 10
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 1.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 10.min * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: SANDPIPER {
    container = "quay.io/biocontainers/singlem:0.20.3--pyhdfd78af_2"
    cpus   = { Math.min( 1 * task.attempt, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 10.min * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: DOWNLOAD_SRR {
    container = "quay.io/asuq1617/iseq:1.9.8-sratools3.4.1"
    maxForks = 10
    cpus   = { Math.min( 4, params.max_cpus as int ) }
    memory = { [ 8.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 12.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: SINGLEM {
    container = "quay.io/biocontainers/singlem:0.20.3--pyhdfd78af_2"
    cpus   = { Math.min( 32 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: FASTP_SHORT {
    container = "quay.io/biocontainers/fastp:1.3.3--h43da1c4_0"
    cpus   = { Math.min( 32 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 6.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: METASPADES {
    container = "quay.io/biocontainers/spades:3.15.5--h5fb382e_3"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: UNICYCLER {
    container = "quay.io/asuq1617/nf-sra_screen_unicycler:0.3.3-spades3.15.5"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: METAFLYE_NANO {
    container = "quay.io/biocontainers/flye:2.9.6--py313h7fbb527_1"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: METAFLYE_PACBIO {
    container = "quay.io/biocontainers/flye:2.9.6--py313h7fbb527_1"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: METAFLYE_HIFI {
    container = "quay.io/biocontainers/flye:2.9.6--py313h7fbb527_1"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: MYLOASM {
    container = "quay.io/biocontainers/myloasm:0.5.1--hd612981_1"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 500.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: MAP_TO_ASSEMBLY {
    container = "quay.io/asuq1617/nf-sra_screen_mapping:${params.version}"
    cpus   = { Math.min( 16 * task.attempt, params.max_cpus as int ) }
    memory = { [ 64.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 24.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: DIAMOND {
    container = "quay.io/biocontainers/diamond:2.1.24--hf93d47f_0"
    cpus   = { Math.min( 128 * task.attempt, params.max_cpus as int ) }
    memory = { [ 100.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 96.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: BLOBTOOLS {
    container = "docker.io/genomehubs/blobtoolkit:4.4.6"
    cpus   = { Math.min( 16, params.max_cpus as int ) }
    memory = { [ 50.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h, params.resource_time_limit() ].min() }
  }

  withName: EXTRACT_TAXA {
    container = "quay.io/asuq1617/nf-sra_screen_taxa:${params.version}"
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 1.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: METABAT {
    container = "quay.io/biocontainers/metabat2:2.18--h38e344b_2"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: COMEBIN {
    container = "quay.io/biocontainers/comebin:1.0.4--hdfd78af_1"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 6.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: COMEBIN_GPU {
    container = "quay.io/asuq1617/comebin:1.0.4-cuda117"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 6.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: VAMB {
    container = "quay.io/biocontainers/vamb:5.0.4--pyhdfd78af_0"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: VAMB_GPU {
    container = "quay.io/asuq1617/vamb:5.0.4-cuda12"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: LORBIN {
    container = "quay.io/asuq1617/lorbin:0.1.0-cpu"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: LORBIN_GPU {
    container = "quay.io/asuq1617/lorbin:0.1.0-gpu"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: SEMIBIN {
    container = "quay.io/biocontainers/semibin:2.2.1--pyhdfd78af_0"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: ROSELLA {
    container = "quay.io/biocontainers/rosella:0.5.7--hfa530fd_0"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: DASTOOL {
    container = "quay.io/biocontainers/das_tool:1.1.7--r44hdfd78af_1"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: BINETTE {
    container = "quay.io/biocontainers/binette:1.2.1--pyh106432d_1"
    cpus   = { Math.min( 32, params.max_cpus as int ) }
    memory = { [ 100.GB, params.resource_memory_limit() ].min() }
    time   = { [ 2.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: CREATE_EMPTY_SUMMARY {
    // Pure shell helpers run on the host to avoid Singularity bind failures.
    executor = 'local'
    maxForks = 10
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 1.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: CREATE_ASSEMBLER_SELECTION_NOTE {
    // Pure shell helper; keep incompatible-assembler notes off the scheduler.
    executor = 'local'
    maxForks = 10
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 1.GB, params.resource_memory_limit() ].min() }
    time   = { [ 10.min * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: CREATE_EMPTY_FAILURE_SUMMARY {
    executor = 'local'
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 4.GB * task.attempt, params.resource_memory_limit() ].min() }
    time   = { [ 1.h * task.attempt, params.resource_time_limit() ].min() }
  }

  withName: APPEND_SUMMARY {
    executor = 'local'
    maxForks = 100
    cpus   = { Math.min( 1, params.max_cpus as int ) }
    memory = { [ 1.GB, params.resource_memory_limit() ].min() }
    time   = { [ 10.min * task.attempt, params.resource_time_limit() ].min() }
  }
}


// --------------------------- Singularity engine -----------------------------
singularity {
  autoMounts  = true
  cacheDir    = params.singularity_cache_dir ?: params.apptainer_cache_dir ?: "${baseDir}/.singularity-cache"
  pullTimeout = params.singularity_pull_timeout ?: params.apptainer_pull_timeout ?: '100m'
  runOptions  = params.singularity_run_options ?: params.apptainer_run_options ?: '--cleanenv'
}


// ---------------------------- Apptainer engine ------------------------------
apptainer {
  autoMounts  = true
  cacheDir    = params.apptainer_cache_dir ?: params.singularity_cache_dir ?: "${baseDir}/.singularity-cache"
  pullTimeout = params.apptainer_pull_timeout ?: params.singularity_pull_timeout ?: '100m'
  runOptions  = params.apptainer_run_options ?: params.singularity_run_options ?: '--cleanenv'
}


// ------------------------------ Reports -------------------------------------
timeline {
  enabled   = true
  file      = "execution-reports/timeline.html"
  overwrite = true
}

report {
  enabled   = true
  file      = "execution-reports/report.html"
  overwrite = true
}

trace {
  enabled   = true
  file      = "execution-reports/trace.tsv"
  overwrite = true
  fields    = "task_id,process,name,tag,status,hash,native_id,cpus,memory,time,realtime,duration,exit,attempt,workdir"
}

includeConfig "${projectDir}/conf/oist.config"
includeConfig "${projectDir}/conf/gwdg.config"
includeConfig "${projectDir}/conf/marmic.config"

// ------------------------------ Profiles ------------------------------------
profiles {
  slurm {
    process.executor = 'slurm'
    singularity.enabled = true
    executor.queueSize = params.executor_queue_size ?: 2000
    params.max_cpus    = 16
    params.max_memory  = 32.GB
    params.max_time    = 24.h
  }

  local {
    process.executor = 'local'
    docker.enabled = true
    executor.queueSize = 4
    params.max_cpus    = 8
    params.max_memory  = 16.GB
    params.max_time    = 24.h
  }

  debug {
    docker.enabled = true
    cleanup = false
    trace.fields = 'task_id,process,name,tag,status,hash,native_id,cpus,memory,time,realtime,exit,attempt,workdir'
    executor.queueSize = 1
    params.max_cpus    = 4
    params.max_memory  = 8.GB
    params.max_time    = 24.h
  }

  test {
  }
}
